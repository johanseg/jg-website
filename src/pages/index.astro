        /* Hero Section */
        .hero {
            padding: 120px 2rem 60px;
            min-height: 80vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                linear-gradient(45deg, rgba(124, 96, 213, 0.03) 25%, transparent 25%),
                linear-gradient(-45deg, rgba(124, 96, 213, 0.03) 25%, transparent 25%),
                linear-gradient(45deg, transparent 75%, rgba(124, 96, 213, 0.03) 75%),
                linear-gradient(-45deg, transparent 75%, rgba(124, 96, 213, 0.03) 75%);
            background-size: 10px 10px;
            background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
            animation: patternMove 30s linear infinite;
            opacity: 0.5;
        }

        .hero::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 20%, rgba(124, 96, 213, 0.05) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(90, 74, 209, 0.05) 0%, transparent 50%);
            pointer-events: none;
            animation: pulse 12s ease-in-out infinite;
        }

        @keyframes patternMove {
            0% {
                background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
                transform: scale(1);
            }
            50% {
                transform: scale(1.1);
            }
            100% {
                background-position: 20px 20px, 20px 30px, 30px 10px, 10px 20px;
                transform: scale(1);
            }
        }

        @keyframes pulse {
            0%, 100% {
                opacity: 0.5;
                transform: scale(1) rotate(0deg);
            }
            50% {
                opacity: 0.7;
                transform: scale(1.1) rotate(1deg);
            }
}

.hero-content {
