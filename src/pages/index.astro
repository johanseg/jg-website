                font-size: 2rem;
            }

            .nav-links {
                display: none;
            }

            .nav-links.show {
        display: flex;
        flex-direction: column;
                position: absolute;
                top: 100%;
                left: 0;
                right: 0;
                background: linear-gradient(135deg, rgba(124, 96, 213, 0.95) 0%, rgba(90, 74, 209, 0.85) 100%);
                backdrop-filter: blur(18px) saturate(1.2);
                -webkit-backdrop-filter: blur(18px) saturate(1.2);
                padding: 50px 2rem 2rem;
                box-shadow: -8px 0 32px rgba(90, 74, 209, 0.18);
                animation: slideIn 0.3s ease-in-out;
                overflow-y: auto;
                z-index: 1000;
                border-radius: 24px;
            }

            .menu-toggle {
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                width: 48px;
                height: 40px;
                background: transparent;
                border: none;
                cursor: pointer;
                padding: 8px;
                z-index: 1001;
                position: fixed;
                top: 20px;
                right: 20px;
                border-radius: 12px;
                transition: background 0.2s;
            }

            .menu-toggle:hover, .menu-toggle:focus {
                background: rgba(124, 96, 213, 0.15);
            }

            .menu-toggle span {
                width: 100%;
                height: 6px;
                background: white;
                border-radius: 6px;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                margin-bottom: 7px;
            }

            .menu-toggle span:last-child {
                margin-bottom: 0;
            }

            .menu-toggle.active span:nth-child(1) {
                transform: translateY(9px) rotate(45deg);
            }

            .menu-toggle.active span:nth-child(2) {
                opacity: 0;
            }

            .menu-toggle.active span:nth-child(3) {
                transform: translateY(-9px) rotate(-45deg);
            }

            .nav-links {
                display: none;
                flex-direction: column;
                background: linear-gradient(135deg, rgba(124, 96, 213, 0.95) 0%, rgba(90, 74, 209, 0.85) 100%);
                backdrop-filter: blur(18px) saturate(1.2);
                -webkit-backdrop-filter: blur(18px) saturate(1.2);
                position: fixed;
                top: 0;
                right: 0;
                height: 100vh;
                width: 240px;
                padding: 50px 2rem 2rem;
                box-shadow: -8px 0 32px rgba(90, 74, 209, 0.18);
                animation: slideIn 0.3s ease-in-out;
                overflow-y: auto;
                z-index: 1000;
                border-radius: 24px;
            }

            .nav-links::after {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 4px;
                height: 100%;
                background: linear-gradient(to bottom, #a18ff7, #3a8dde);
            }

            .nav-links.show {
	  display: flex;
            }

            .nav-links li {
                margin: 1rem 0;
                opacity: 0;
                transform: translateX(20px);
                animation: fadeInRight 0.3s ease forwards;
                position: relative;
            }

            .nav-links li::before {
                display: none;
            }

            .nav-links li:hover::before {
                display: none;
            }

            .nav-links a {
                display: flex;
                align-items: center;
                padding: 1rem 1.5rem;
                font-size: 1.1rem;
	            border-radius: 8px; 
                color: white;
                text-decoration: none;
                transition: all 0.3s ease;
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                position: relative;
                overflow: hidden;
            }

            .nav-links a::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(120deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.38) 60%, rgba(255,255,255,0.12) 100%);
                transform: skewX(-25deg) translateX(-100%);
                opacity: 0;
                transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), opacity 0.2s;
                pointer-events: none;
                z-index: 2;
                border-radius: inherit;
            }

            .nav-links a:hover::before, .nav-links a:focus::before {
                transform: skewX(-25deg) translateX(100%);
                opacity: 1;
                transition: transform 0.5s cubic-bezier(0.4,0,0.2,1), opacity 0.2s;
            }

            .nav-links a:hover {
                background: rgba(255, 255, 255, 0.15);
                transform: translateX(5px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }

            /* Footer del menú */
            .nav-links::before {
                content: '© 2024';
                position: absolute;
                bottom: 20px;
                left: 50%;
                transform: translateX(-50%);
                color: rgba(255, 255, 255, 0.5);
                font-size: 0.8rem;
            }

            /* Estilo para el scrollbar */
            .nav-links::-webkit-scrollbar {
                width: 5px;
            }

            .nav-links::-webkit-scrollbar-track {
                background: rgba(255, 255, 255, 0.1);
            }

            .nav-links::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.3);
                border-radius: 5px;
            }

            .nav-links::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.5);
            }

            body.menu-open {
                overflow-y: scroll;
            }

            .hero-content {
                padding-top: 60px; /* Espacio para el botón del menú */
            }

            .nav-links a::after {
                display: none !important;
            }
        }

        @keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @media (min-width: 769px) {
            .nav-links {
                display: flex !important;
                flex-direction: row;
                align-items: center;
                gap: 2.5rem;
                background: linear-gradient(90deg, rgba(124,96,213,0.18) 0%, rgba(58,141,222,0.18) 100%);
                backdrop-filter: blur(8px) saturate(1.2);
                -webkit-backdrop-filter: blur(8px) saturate(1.2);
                border-radius: 2rem;
                box-shadow: 0 2px 16px 0 rgba(124, 96, 213, 0.10);
                border: 3px solid #b7aefa;
                padding: 0.5rem 2.5rem;
                margin: 0 auto;
                position: relative;
                width: fit-content;
            }
            .nav-links a {
                color: #fff;
                font-size: 1.25rem;
                font-weight: 600;
                padding: 0.7rem 1.2rem;
                border-radius: 1.5rem;
                background: transparent;
                border: none;
                transition: color 0.3s;
                box-shadow: none;
                text-shadow: 0 1px 4px rgba(124,96,213,0.08);
                letter-spacing: 0.5px;
                position: relative;
                text-decoration: none;
                display: flex;
                align-items: center;
                justify-content: center;
                height: 100%;
            }
            .nav-links a::after {
                content: '';
                position: absolute;
                left: 50%;
                right: 50%;
                bottom: 2px;
                height: 2.5px;
                background: linear-gradient(90deg, #fff 0%, #7c60d5 100%);
                border-radius: 2px;
                opacity: 0;
                transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
            }
            .nav-links a:hover, .nav-links a:focus {
                color: #fff;
            }
            .nav-links a:hover::after, .nav-links a:focus::after {
                left: 0;
                right: 0;
                opacity: 1;
            }
        }

        .about, .services, .case-studies, .contact {
            width: 80vw !important;
            max-width: 1200px !important;
            margin-left: auto !important;
            margin-right: auto !important;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toggleButton = document.querySelector('.menu-toggle');
            const navLinks = document.querySelector('.nav-links');
            const body = document.body;
    
            if (toggleButton && navLinks) {
                toggleButton.addEventListener('click', () => {
                    toggleButton.classList.toggle('active');
                    navLinks.classList.toggle('show');
                    body.classList.toggle('menu-open');
                });

                // Cerrar menú al hacer clic en un enlace
                const navItems = navLinks.querySelectorAll('a');
                navItems.forEach(item => {
                    item.addEventListener('click', () => {
                        toggleButton.classList.remove('active');
                        navLinks.classList.remove('show');
                        body.classList.remove('menu-open');
                    });
                });

                // Cerrar menú al hacer clic fuera

            }
        });
    </script>
</body>
</html>
