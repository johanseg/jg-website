            animation: float 8s ease-in-out infinite;
            position: relative;
        }

        .hero-photo::after {
            content: '';
            position: absolute;
            top: -5px;
            left: -5px;
            right: -5px;
            bottom: -5px;
            border-radius: 50%;
            background: linear-gradient(45deg, rgba(124, 96, 213, 0.1), transparent);
            z-index: -1;
