            display: flex;
            align-items: center;
            gap: 4rem;
            position: relative;
            z-index: 1;
            animation: contentFade 1s ease-out;
        }

        @keyframes contentFade {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
}

