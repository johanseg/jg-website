---
const { imageSrc, title, description } = Astro.props;
---

<div class="card">
  <img src={imageSrc} alt={title} class="card-image" />
  <div class="card-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
.card {
  display: flex;
  align-items: center;
  border: 1px solid #e0e0e0;
  padding: 1.5rem;
  border-radius: 10px;
  margin-bottom: 1.5rem;
  transition: background-color 0.3s ease; 
}

.card:hover {
  background-color: #a08fd6; 
  color: aliceblue; 
}

.card:hover .card-content h3 {
  color: white; 
}

.card-image {
  width: 80px;
  height: 80px;
  object-fit: cover;
  margin-right: 1.5rem;
}

.card-content h3 {
  font-size: 1.5rem;
  color: #7c60d5; 
  margin-bottom: 0.5rem;
  transition: color 0.3s ease;
}

.card-content p {
  font-size: 1rem;
  color: #333;
}
</style>
