---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Johan Garcia — AI-powered growth strategist. 13+ years scaling revenue with performance marketing, generative AI, and automation for brands like Warner Bros. Games, Meta, and more." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://johangarcia.com" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

	:root {
		--bg: #08090d;
		--bg-elevated: #0e1018;
		--bg-card: #12141c;
		--surface: #181a24;
		--border: rgba(255, 255, 255, 0.06);
		--text: #e8e9ed;
		--text-muted: #8a8d9b;
		--text-dim: #555869;
		--accent: #00e5a0;
		--accent-glow: rgba(0, 229, 160, 0.15);
		--accent-bright: #33ffbd;
		--accent-2: #6366f1;
		--accent-2-glow: rgba(99, 102, 241, 0.15);
		--accent-3: #f472b6;
		--gradient-main: linear-gradient(135deg, #00e5a0, #6366f1, #f472b6);
		--font-display: 'Outfit', sans-serif;
		--font-mono: 'JetBrains Mono', monospace;
		--ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
		--ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	html {
		font-family: var(--font-display);
		background: var(--bg);
		color: var(--text);
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
	}

	body {
		min-height: 100vh;
		line-height: 1.6;
		overflow-x: hidden;
	}

	::selection {
		background: rgba(0, 229, 160, 0.25);
		color: #fff;
	}

	a { color: inherit; text-decoration: none; }
	img { max-width: 100%; height: auto; display: block; }
	ul { list-style: none; }
</style>
