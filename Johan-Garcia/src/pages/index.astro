}

.t-kw { color: #c678dd; }
.t-mod { color: #e5c07b; }
.t-fn { color: #61afef; }
.t-str { color: #98c379; }
.t-key { color: #e06c75; }
.t-bool { color: #d19a66; }
.t-num { color: #d19a66; }
