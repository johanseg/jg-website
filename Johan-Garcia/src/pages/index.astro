	left: 7px;
	top: 8px;
	bottom: 8px;
	width: 1px;
	background: linear-gradient(to bottom, var(--accent), var(--accent-2), var(--accent-3), transparent);
}

.timeline__item {
	position: relative;
	padding-bottom: 3rem;
}

.timeline__item:last-child {
